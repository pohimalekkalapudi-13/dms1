<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SR — Artisan Chocolates</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Poppins:wght@300;400;500;600&display=swap');
  body {
    font-family: 'Poppins', sans-serif;
    background: #1a0f0a;
    color: #f5e6d3;
    overflow-x: hidden;
  }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 50px;
    background: rgba(26, 15, 10, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(212, 165, 116, 0.2);
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 32px; font-weight: 900;
    background: linear-gradient(135deg, #d4a574, #8b4513);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 2px;
    position: relative;
  }
  .logo::before {
    content: '♛';
    position: absolute;
    top: -18px; left: -2px;
    font-size: 18px; color: #d4a574;
    text-shadow: 0 0 8px rgba(212,165,116,0.6);
  }
  .nav-btn {
    background: linear-gradient(135deg, #d4a574, #8b4513);
    border: none; color: #1a0f0a;
    padding: 10px 24px; border-radius: 25px;
    font-weight: 600; cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .nav-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(212,165,116,0.4); }

  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 120px 20px 60px;
    position: relative;
  }
  .hero::before {
    content: ''; position: absolute;
    top: 10%; left: 50%; transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(212,165,116,0.15) 0%, transparent 70%);
  }
  .chocolate-bar {
    position: relative;
    width: 90%; max-width: 700px;
    height: 180px;
    background: linear-gradient(180deg, #5c3317 0%, #3a1f0f 50%, #2a150a 100%);
    border-radius: 12px;
    margin-bottom: 50px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6), inset 0 2px 4px rgba(255,255,255,0.1), inset 0 -2px 4px rgba(0,0,0,0.3);
    overflow: visible;
  }
  .chocolate-bar::before {
    content: '';
    position: absolute; inset: 0; border-radius: 12px;
    background-image: repeating-linear-gradient(90deg, transparent 0, transparent calc(100% / 6 - 2px), rgba(0,0,0,0.4) calc(100% / 6 - 2px), rgba(0,0,0,0.4) calc(100% / 6));
  }
  .chocolate-bar::after {
    content: ''; position: absolute;
    bottom: -40px; left: 0; right: 0; height: 60px;
    background:
      radial-gradient(ellipse 40px 40px at 15% 0%, #5c3317 50%, transparent 51%),
      radial-gradient(ellipse 60px 60px at 35% 0%, #4a2810 50%, transparent 51%),
      radial-gradient(ellipse 35px 35px at 55% 0%, #5c3317 50%, transparent 51%),
      radial-gradient(ellipse 50px 50px at 78% 0%, #3a1f0f 50%, transparent 51%),
      radial-gradient(ellipse 30px 30px at 92% 0%, #5c3317 50%, transparent 51%);
    filter: blur(1px);
  }
  .chocolate-bar span {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Playfair Display', serif;
    font-size: 90px; font-weight: 900;
    color: #f5e6d3;
    text-shadow: 2px 2px 0 #2a150a, -1px -1px 0 #8b4513, 0 0 20px rgba(245, 230, 211, 0.3);
    letter-spacing: 8px;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 64px; margin-bottom: 20px;
    background: linear-gradient(135deg, #f5e6d3 0%, #d4a574 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero p { font-size: 20px; color: #c9a47a; max-width: 600px; margin-bottom: 40px; }
  .ig-btn {
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    border: none; color: white;
    padding: 16px 40px; border-radius: 30px;
    font-size: 18px; font-weight: 600;
    cursor: pointer;
    display: inline-flex; align-items: center; gap: 12px;
    box-shadow: 0 10px 30px rgba(220, 39, 67, 0.4);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .ig-btn:hover { transform: translateY(-3px) scale(1.05); box-shadow: 0 15px 40px rgba(220, 39, 67, 0.6); }

  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
    display: none; align-items: center; justify-content: center;
    z-index: 200;
  }
  .modal-overlay.active { display: flex; }
  .modal {
    background: linear-gradient(180deg, #2a150a, #1a0f0a);
    border: 1px solid rgba(212,165,116,0.3);
    border-radius: 20px;
    padding: 40px;
    width: 90%; max-width: 480px;
    position: relative; text-align: center;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
  }
  .modal-close {
    position: absolute; top: 15px; right: 20px;
    background: none; border: none;
    color: #c9a47a; font-size: 24px; cursor: pointer;
  }
  .modal h2 {
    font-family: 'Playfair Display', serif;
    font-size: 28px; color: #f5e6d3; margin-bottom: 15px;
  }
  .modal p {
    color: #c9a47a; font-size: 15px; line-height: 1.7;
    margin-bottom: 20px;
  }
  .modal strong { color: #d4a574; }
  .modal-cta {
    background: linear-gradient(135deg, #d4a574, #8b4513);
    border: none; color: #1a0f0a;
    padding: 12px 32px; border-radius: 25px;
    font-weight: 600; cursor: pointer;
    font-size: 15px;
    transition: transform 0.2s;
  }
  .modal-cta:hover { transform: scale(1.05); }
  .modal .small { font-size: 12px; color: #6b5040; margin-top: 15px; }

  #store { padding: 50px 50px 60px; }
  .store-header {
    text-align: center; margin-bottom: 60px; padding-top: 40px;
  }
  .store-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 48px; color: #d4a574; margin-bottom: 10px;
  }
  .store-header p { color: #c9a47a; }
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 30px; max-width: 1400px; margin: 0 auto;
  }
  .card {
    background: #2a150a; border-radius: 16px; overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    transition: transform 0.4s, box-shadow 0.4s;
    border: 1px solid rgba(212,165,116,0.15);
  }
  .card:hover { transform: translateY(-10px); box-shadow: 0 20px 50px rgba(212,165,116,0.2); }
  .card-img { width: 100%; height: 280px; object-fit: cover; display: block; background: #1a0f0a; }
  .card-body { padding: 20px; }
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px; color: #f5e6d3; margin-bottom: 8px;
  }
  .card-desc { color: #c9a47a; font-size: 14px; margin-bottom: 15px; }
  .card-price { color: #d4a574; font-weight: 600; font-size: 20px; }

  @media (max-width: 600px) {
    nav { padding: 15px 20px; }
    .hero h1 { font-size: 42px; }
    .chocolate-bar { height: 130px; }
    .chocolate-bar span { font-size: 60px; }
    #store { padding: 30px 20px 40px; }
    .store-header h2 { font-size: 36px; }
  }
</style>
</head>
<body>

<nav>
  <div class="logo">SR</div>
  <button class="nav-btn" onclick="openModal()">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
    Login with Instagram
  </button>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="chocolate-bar"><span>SR</span></div>
  <h1>Sweet. Rich. Unforgettable.</h1>
  <p>Handcrafted artisan chocolates, made for the moments that matter.</p>
  <button class="ig-btn" onclick="openModal()">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
    Login with Instagram
  </button>
</section>

<!-- MODAL -->
<div class="modal-overlay" id="infoModal" onclick="if(event.target===this) closeModal()">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">&times;</button>
    <div style="font-size:48px;margin-bottom:15px;">🍫</div>
    <h2>Meta Partnership Coming Soon</h2>
    <p>
      We're finalizing our Meta partnership approval. Once live, you'll sign in 
      securely through <strong>Instagram's official authentication</strong> &mdash; 
      handled entirely by Meta, never passing through our servers.
    </p>
    <p>
      <strong>In the meantime:</strong> Browse our full chocolate collection below. 
      No login required.
    </p>
    <button class="modal-cta" onclick="closeModal();document.getElementById('store').scrollIntoView({behavior:'smooth'})">
      Browse Chocolates
    </button>
    <p class="small">Your credentials are safe with Meta &mdash; we never see them.</p>
  </div>
</div>

<!-- STORE -->
<section id="store">
  <div class="store-header">
    <h2>Our Chocolate Collection</h2>
    <p>Handcrafted with love. Always.</p>
  </div>
  <div class="gallery" id="gallery"></div>
</section>

<script>
  const chocolates = [
    { name: "Dark Truffle",      desc: "70% Belgian dark chocolate, hand-rolled.", price: "$12", img: "https://images.unsplash.com/photo-1606312619070-d48b4c652a52?w=600&q=80" },
    { name: "Golden Praline",    desc: "Hazelnut praline draped in 24k gold dust.", price: "$18", img: "https://images.unsplash.com/photo-1548907040-4baa42d10919?w=600&q=80" },
    { name: "Ruby Ganache",      desc: "Rare ruby cacao with raspberry notes.", price: "$15", img: "https://images.unsplash.com/photo-1481391319762-47dff72954d9?w=600&q=80" },
    { name: "Caramel Heart",     desc: "Soft caramel in a milk chocolate shell.", price: "$10", img: "https://images.unsplash.com/photo-1511381939415-e44015466834?w=600&q=80" },
    { name: "Espresso Bite",     desc: "Dark chocolate with a jolt of espresso.", price: "$11", img: "https://images.unsplash.com/photo-1623660053975-cf75a8be0908?w=600&q=80" },
    { name: "Salted Pistachio",  desc: "Sea salt and roasted pistachio crunch.", price: "$14", img: "https://images.unsplash.com/photo-1542843137-8791a6904d14?w=600&q=80" },
    { name: "Velvet Bonbon",     desc: "Smooth ganache in a glossy shell.", price: "$13", img: "https://images.unsplash.com/photo-1582176604856-e824b4736522?w=600&q=80" },
    { name: "Mint Whisper",      desc: "Cool peppermint in dark chocolate.", price: "$9",  img: "https://images.unsplash.com/photo-1626058239339-d4a914b5f5b8?w=600&q=80" },
    { name: "Hazelnut Dream",    desc: "Whole hazelnut center, milk chocolate.", price: "$12", img: "https://images.unsplash.com/photo-1599599810694-b5b37304c041?w=600&q=80" },
  ];

  function openModal() { document.getElementById('infoModal').classList.add('active'); }
  function closeModal() { document.getElementById('infoModal').classList.remove('active'); }
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

  const gallery = document.getElementById('gallery');
  gallery.innerHTML = chocolates.map(function(c) {
    return '<div class="card">' +
      '<img class="card-img" src="' + c.img + '" alt="' + c.name + '" loading="lazy" onerror="this.src=\'https://placehold.co/600x400/3a1f0f/d4a574?text=' + encodeURIComponent(c.name) + '\'">' +
      '<div class="card-body">' +
      '<div class="card-title">' + c.name + '</div>' +
      '<div class="card-desc">' + c.desc + '</div>' +
      '<div class="card-price">' + c.price + '</div>' +
      '</div></div>';
  }).join('');
</script>
</body>
</html>
